  <script>
    /* ── Position rotating circle on phone in background image ── */
    (function() {
      // Phone position in the ORIGINAL image (as fraction 0-1)
      // These are the coordinates of the phone in the source image
      var PHONE_X = 0.58;  // 58% from left in original image
      var PHONE_Y = 0.30;  // 30% from top in original image
      var IMG_NATURAL_W = 2246;  // exact natural width of hero image
      var IMG_NATURAL_H = 1224;  // exact natural height of hero image

      var circle = document.querySelector('.rotating-circle');
      var hero = document.querySelector('.hero');

      function positionCircle() {
        if (!circle || !hero) return;

        var vw = hero.offsetWidth;
        var vh = hero.offsetHeight;
        var imgRatio = IMG_NATURAL_W / IMG_NATURAL_H;
        var containerRatio = vw / vh;

        var renderW, renderH, offsetX, offsetY;

        if (containerRatio > imgRatio) {
          // Container is wider — image scaled by width, cropped top/bottom
          renderW = vw;
          renderH = vw / imgRatio;
          offsetX = 0;
          offsetY = 0; // background-position: center top → no top offset
        } else {
          // Container is taller — image scaled by height, cropped sides
          renderH = vh;
          renderW = vh * imgRatio;
          offsetX = (vw - renderW) / 2; // background-position: center → centered horizontally
          offsetY = 0; // top aligned
        }

        var phoneScreenX = offsetX + (PHONE_X * renderW);
        var phoneScreenY = offsetY + (PHONE_Y * renderH);

        circle.style.left = phoneScreenX + 'px';
        circle.style.top = phoneScreenY + 'px';
        circle.style.transform = 'translate(-50%, -50%)';
      }

      positionCircle();
      window.addEventListener('resize', positionCircle);
      // Also reposition after fonts/images load
      window.addEventListener('load', positionCircle);
    })();

    /* ── Navbar scroll: transparent on hero + footer, scrolled in between ── */
    window.addEventListener('scroll', function() {
      var nav = document.querySelector('.navbar');
      var footer = document.querySelector('.footer-new');
      var isPastHero = window.scrollY > 80;
      var footerInView = false;

      if (footer) {
        var rect = footer.getBoundingClientRect();
        // Footer is "in view" once its top crosses below the navbar height (~80px)
        footerInView = rect.top < 80;
      }

      if (isPastHero && !footerInView) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });

    /* ── Mobile menu ── */
    function toggleMobileMenu() {
      document.getElementById('mobileMenu').classList.toggle('open');
    }
    function closeMobileMenu() {
      document.getElementById('mobileMenu').classList.remove('open');
    }

    /* ── Intersection Observer for fade-up ── */
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.fade-up').forEach(function(el) {
      observer.observe(el);
    });

    /* ── Transcript typing animation + notification stack ── */
    (function() {
      var body = document.getElementById('transcriptBody');
      var cards = [
        document.getElementById('smsCard1'),
        document.getElementById('smsCard2'),
        document.getElementById('emailCard')
      ];
      var charDelay = 35;

      var messages = [
        { sender: 'kunde', label: 'Kunde', text: 'Ja, Dienstag 9 Uhr passt mir gut.', delay: 800 },
        { sender: 'kunde', label: 'Kunde', text: 'K\u00f6nnen Sie auch gleich die Regenrinne anschauen?', delay: 600 },
        { sender: 'handwerker', label: 'Handwerker', text: 'Klar, mach ich.', delay: 1200 },
        { sender: 'handwerker', label: 'Handwerker', text: 'Ich bring das Material f\u00fcr beides mit.', delay: 400 }
      ];

      function resetCards() {
        cards.forEach(function(card) {
          if (!card) return;
          card.classList.remove('visible', 'stacked-1', 'stacked-2');
        });
      }

      function showCard(index) {
        // The new card becomes visible (front)
        var card = cards[index];
        if (!card) return;
        card.classList.add('visible');

        // Push older cards back in the stack
        for (var i = index - 1; i >= 0; i--) {
          var older = cards[i];
          if (!older) continue;
          var depth = index - i; // 1 = one behind, 2 = two behind
          older.classList.remove('stacked-1', 'stacked-2');
          if (depth === 1) older.classList.add('stacked-1');
          if (depth >= 2) older.classList.add('stacked-2');
        }
      }

      function runAnimation() {
        body.innerHTML = '';
        resetCards();
        var msgIndex = 0;

        function nextMessage() {
          if (msgIndex >= messages.length) {
            body.querySelectorAll('.cursor-blink').forEach(function(c) { c.remove(); });
            // Show notifications one by one, stacking
            setTimeout(function() {
              showCard(0); // SMS an dich
              setTimeout(function() {
                showCard(1); // SMS an Frau Meier — pushes card 0 back
                setTimeout(function() {
                  showCard(2); // E-Mail ans Büro — pushes 0+1 back
                  setTimeout(runAnimation, 4500);
                }, 1200);
              }, 1200);
            }, 1000);
            return;
          }

          var msg = messages[msgIndex];
          msgIndex++;

          setTimeout(function() {
            body.querySelectorAll('.cursor-blink').forEach(function(c) { c.remove(); });

            var bubble = document.createElement('div');
            bubble.className = 'chat-bubble ' + msg.sender;

            var senderEl = document.createElement('div');
            senderEl.className = 'bubble-sender';
            senderEl.textContent = msg.label;
            bubble.appendChild(senderEl);

            var textEl = document.createElement('span');
            bubble.appendChild(textEl);

            var cursor = document.createElement('span');
            cursor.className = 'cursor-blink';
            cursor.textContent = '|';
            bubble.appendChild(cursor);

            body.appendChild(bubble);
            body.scrollTop = body.scrollHeight;

            var chars = msg.text.split('');
            var charIndex = 0;

            function typeChar() {
              if (charIndex < chars.length) {
                textEl.textContent += chars[charIndex];
                charIndex++;
                body.scrollTop = body.scrollHeight;
                setTimeout(typeChar, charDelay);
              } else {
                nextMessage();
              }
            }
            typeChar();
          }, msg.delay);
        }

        nextMessage();
      }

      setTimeout(runAnimation, 800);
    })();

    /* ── How it works auto-progress carousel ── */
    (function() {
      var features = document.querySelectorAll('.how-feature');
      var iphones = document.querySelectorAll('.how-visual-iphone');
      var actionCards = document.querySelectorAll('.how-action-scene');
      if (!features.length) return;

      var currentIndex = 0;
      var intervalMs = 10000;
      var timer = null;

      function setActive(index) {
        currentIndex = index;
        features.forEach(function(el, i) {
          el.classList.toggle('active', i === index);
          if (i === index) {
            var bar = el.querySelector('.how-feature-progress-bar');
            if (bar) {
              bar.style.animation = 'none';
              void bar.offsetWidth;
              bar.style.animation = '';
            }
          }
        });
        iphones.forEach(function(el, i) {
          el.classList.toggle('active', i === index);
        });
        actionCards.forEach(function(el, i) {
          el.classList.toggle('active', i === index);
        });
      }

      function next() {
        setActive((currentIndex + 1) % features.length);
      }

      function startTimer() {
        clearInterval(timer);
        timer = setInterval(next, intervalMs);
      }

      // Click to jump
      features.forEach(function(el, i) {
        el.addEventListener('click', function() {
          setActive(i);
          startTimer();
        });
      });

      // Start auto-progression when section is visible
      var section = document.querySelector('.how-new');
      if (section && 'IntersectionObserver' in window) {
        var sectionObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              startTimer();
            } else {
              clearInterval(timer);
            }
          });
        }, { threshold: 0.3 });
        sectionObserver.observe(section);
      } else {
        startTimer();
      }
    })();

    /* ── Image comparison slider (angled, clip-path synced) ── */
    (function() {
      var container = document.getElementById('sliderCompare');
      if (!container) return;

      var handle = document.getElementById('sliderHandle');
      var SKEW = 10;
      var isDragging = false;

      function setPosition(pct) {
        pct = Math.max(15, Math.min(85, pct));
        var top = pct - SKEW;
        var bot = pct + SKEW;
        container.style.setProperty('--sl-top', top + '%');
        container.style.setProperty('--sl-bot', bot + '%');
        handle.style.left = pct + '%';
        handle.style.top = '50%';

        // Fade overlays + animate text lines
        function updateOverlay(el, intensity) {
          if (!el) return;
          el.style.opacity = Math.min(1, intensity);
          el.style.transform = 'translateY(' + (6 - Math.min(1, intensity) * 6) + 'px)';
          el.querySelectorAll('.slider-overlay-line').forEach(function(line) {
            var t = parseFloat(line.getAttribute('data-threshold')) || 0.5;
            line.classList.toggle('show', intensity > t);
          });
        }
        var olL = document.getElementById('sliderOL1L');
        var olR = document.getElementById('sliderOL1R');
        updateOverlay(olL, (pct - 45) / 25);  // starts at 45%, full at 70%
        updateOverlay(olR, (45 - pct + 10) / 25);  // starts at 55%, full at 30%
      }

      function getPercent(e) {
        var rect = container.getBoundingClientRect();
        var clientX = e.touches ? e.touches[0].clientX : e.clientX;
        return ((clientX - rect.left) / rect.width) * 100;
      }

      container.addEventListener('mousedown', function(e) { isDragging = true; setPosition(getPercent(e)); });
      container.addEventListener('touchstart', function(e) { isDragging = true; setPosition(getPercent(e)); }, { passive: true });
      window.addEventListener('mousemove', function(e) { if (isDragging) setPosition(getPercent(e)); });
      window.addEventListener('touchmove', function(e) { if (isDragging) setPosition(getPercent(e)); }, { passive: true });
      window.addEventListener('mouseup', function() { isDragging = false; });
      window.addEventListener('touchend', function() { isDragging = false; });

      setPosition(55);
    })();

    /* ── Second slider (Card 3) ── */
    (function() {
      var container = document.getElementById('sliderCompare2');
      if (!container) return;

      var handle = document.getElementById('sliderHandle2');
      var SKEW = 10;
      var isDragging = false;

      function setPosition(pct) {
        pct = Math.max(15, Math.min(85, pct));
        var top = pct - SKEW;
        var bot = pct + SKEW;
        container.style.setProperty('--sl-top', top + '%');
        container.style.setProperty('--sl-bot', bot + '%');
        handle.style.left = pct + '%';
        handle.style.top = '50%';

        function updateOverlay2(el, intensity) {
          if (!el) return;
          el.style.opacity = Math.min(1, intensity);
          el.style.transform = 'translateY(' + (6 - Math.min(1, intensity) * 6) + 'px)';
          el.querySelectorAll('.slider-overlay-line').forEach(function(line) {
            var t = parseFloat(line.getAttribute('data-threshold')) || 0.5;
            line.classList.toggle('show', intensity > t);
          });
        }
        var olL = document.getElementById('sliderOL2L');
        var olR = document.getElementById('sliderOL2R');
        updateOverlay2(olL, (pct - 45) / 25);
        updateOverlay2(olR, (45 - pct + 10) / 25);
      }

      function getPercent(e) {
        var rect = container.getBoundingClientRect();
        var clientX = e.touches ? e.touches[0].clientX : e.clientX;
        return ((clientX - rect.left) / rect.width) * 100;
      }

      container.addEventListener('mousedown', function(e) { isDragging = true; setPosition(getPercent(e)); });
      container.addEventListener('touchstart', function(e) { isDragging = true; setPosition(getPercent(e)); }, { passive: true });
      window.addEventListener('mousemove', function(e) { if (isDragging) setPosition(getPercent(e)); });
      window.addEventListener('touchmove', function(e) { if (isDragging) setPosition(getPercent(e)); }, { passive: true });
      window.addEventListener('mouseup', function() { isDragging = false; });
      window.addEventListener('touchend', function() { isDragging = false; });

      setPosition(55);
    })();

    /* ── Step 2 animated transcript ── */
    (function() {
      var container = document.getElementById('step2Transcript');
      if (!container) return;

      var messages = [
        { sender: 'kunde', text: 'Hallo, hier Meier. Ich bräuchte jemanden für die Dachrinne.' },
        { sender: 'handwerker', text: 'Frau Meier! Was genau ist das Problem?' },
        { sender: 'kunde', text: 'Die Regenrinne an der Westseite tropft. Und die Fensterdichtung im Bad müsste auch geschaut werden.' },
        { sender: 'handwerker', text: 'Mach ich beides. Passt Ihnen Dienstag 9 Uhr?' },
        { sender: 'kunde', text: 'Perfekt. Brauchen Sie einen Schlüssel?' },
        { sender: 'handwerker', text: 'Nein, ich klingle einfach. Bring das Material für beides mit.' },
        { sender: 'kunde', text: 'Super, dann bis Dienstag!' }
      ];

      var step2Active = false;
      var animRunning = false;

      var charDelay = 30;

      function runTranscriptAnim() {
        if (animRunning) return;
        animRunning = true;
        container.innerHTML = '';

        var msgIdx = 0;
        function nextMessage() {
          if (msgIdx >= messages.length || !step2Active) { animRunning = false; return; }
          var msg = messages[msgIdx];
          msgIdx++;

          // Remove old cursor
          var oldCursor = container.querySelector('.cursor-blink');
          if (oldCursor) oldCursor.remove();

          // Create bubble
          var bubble = document.createElement('div');
          bubble.className = 'chat-bubble ' + msg.sender;
          var label = document.createElement('div');
          label.className = 'bubble-sender';
          label.textContent = msg.sender === 'kunde' ? 'Kunde' : 'Handwerker';
          bubble.appendChild(label);

          var textSpan = document.createElement('span');
          bubble.appendChild(textSpan);

          var cursor = document.createElement('span');
          cursor.className = 'cursor-blink';
          cursor.textContent = '|';
          bubble.appendChild(cursor);

          container.appendChild(bubble);
          container.scrollTop = container.scrollHeight;

          // Type character by character
          var chars = msg.text.split('');
          var charIdx = 0;
          function typeChar() {
            if (charIdx < chars.length && step2Active) {
              textSpan.textContent += chars[charIdx];
              charIdx++;
              container.scrollTop = container.scrollHeight;
              setTimeout(typeChar, charDelay);
            } else {
              cursor.remove();
              setTimeout(nextMessage, 600);
            }
          }
          typeChar();
        }
        setTimeout(nextMessage, 400);
      }

      // Watch for step 2 becoming active
      var observer = new MutationObserver(function() {
        var scene = document.querySelector('.how-action-scene[data-step="2"]');
        if (scene && scene.classList.contains('active')) {
          if (!step2Active) {
            step2Active = true;
            runTranscriptAnim();
          }
        } else {
          step2Active = false;
          animRunning = false;
        }
      });

      var stage = document.querySelector('.how-action-stage');
      if (stage) observer.observe(stage, { subtree: true, attributes: true, attributeFilter: ['class'] });
    })();

    /* ── Smooth scroll for anchor links ── */
    document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
      anchor.addEventListener('click', function(e) {
        var target = document.querySelector(this.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  </script>


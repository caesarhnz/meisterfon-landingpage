    }

    .about-modal-header {
      text-align: center;
      margin-bottom: 36px;
    }

    .about-founders-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 32px;
    }

    .about-founder-card {
      background: rgba(40,37,36,0.03);
      border: 1px solid rgba(40,37,36,0.08);
      border-radius: 16px;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .about-avatar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(40,37,36,0.12), rgba(40,37,36,0.06));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }

    .about-avatar span {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 1.4rem;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .about-founder-name {
      font-family: 'Archivo', sans-serif !important;
      font-weight: 700 !important;
      font-size: 1.2rem !important;
      color: var(--text) !important;
      letter-spacing: -0.02em !important;
      text-transform: none !important;
      margin-bottom: 4px !important;
    }

    .about-founder-role {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      font-size: 0.82rem;
      color: var(--text-secondary);
      margin-bottom: 18px;
    }

    .about-founder-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
    }

    .about-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 0.78rem;
      color: var(--text);
      background: var(--white);
      border: 1px solid rgba(40,37,36,0.12);
      border-radius: 9999px;
      padding: 7px 14px;
      text-decoration: none;
      transition: border-color 0.2s ease, background 0.2s ease;
    }

    .about-pill:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .about-call-block {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      background: rgba(40,37,36,0.03);
      border: 1px solid rgba(40,37,36,0.08);
      border-radius: 16px;
      padding: 24px;
    }

    .about-call-icon {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--white);
      border: 1px solid rgba(40,37,36,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .about-call-label {
      font-family: 'Archivo', sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text);
      margin-bottom: 4px;
    }

    .about-call-number {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 1.3rem;
      color: var(--accent);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

